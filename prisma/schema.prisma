generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VaultItemType {
  API_KEY
  PASSWORD
  NOTE
  OTHER
}

enum BlockPriority {
  LOW
  MEDIUM
  HIGH
  SACRED
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum BlockCategory {
  MORNING_ROUTINE
  DEEP_WORK
  LEARNING
  OFFICE_WORK
  MEETINGS
  CONTENT_CREATION
  READING
  WORKOUT
  PRAYER
  FAMILY_TIME
  BREAK
  SLEEP
  CUSTOM
}

enum SchedulingMode {
  FLEXIBLE
  FIXED
}

enum ScheduleSource {
  GENERATED
  MANUAL
  TEMPLATE
}

enum ScheduledBlockStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  SKIPPED
  MISSED
}

enum RuleSeverity {
  INFO
  IMPORTANT
  SACRED
}

enum AuditAction {
  VAULT_READ
  VAULT_CREATE
  VAULT_UPDATE
  VAULT_DELETE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts         Account[]
  sessions         Session[]
  profile          Profile?
  tasks            Task[]
  vaultItems       VaultItem[]
  categories       Category[]
  routineBlocks    RoutineBlock[]
  routineTemplates RoutineTemplate[]
  scheduleDays     ScheduleDay[]
  personalRules    PersonalRule[]
  prayerTimeCaches PrayerTimeCache[]
  auditLogs        AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  timezone           String   @default("UTC")
  country            String   @default("US")
  language           String   @default("en")
  profession         String?
  workingHours       Json?
  sleepSchedule      Json?
  prayerPreference   String?
  energyProfile      Json?
  weekendRules       Json?
  ramadanMode        Boolean  @default(false)
  prayerMethod       Int      @default(1)
  city               String?
  latitude           Float?
  longitude          Float?
  autoAdaptSchedule  Boolean  @default(false)
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
}

model Tag {
  id    String @id @default(cuid())
  name  String
  tasks Task[] @relation("TaskTags")
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  categoryId  String?
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  autoSchedule Boolean     @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id])
  tags            Tag[]            @relation("TaskTags")
  scheduledBlocks ScheduledBlock[]

  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([deletedAt])
}

model VaultItem {
  id               String        @id @default(cuid())
  userId           String
  title            String
  encryptedPayload String        @db.Text
  iv               String
  type             VaultItemType @default(NOTE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
}

model RoutineTemplate {
  id         String    @id @default(cuid())
  userId     String?
  name       String
  profession String?
  isSystem   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  user   User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks RoutineBlock[]

  @@index([userId])
}

model RoutineBlock {
  id                String         @id @default(cuid())
  userId            String?
  templateId        String?
  title             String
  icon              String         @default("clock")
  color             String         @default("#4a3aa7")
  durationMinutes   Int            @default(60)
  priority          BlockPriority  @default(MEDIUM)
  energyLevel       EnergyLevel    @default(MEDIUM)
  category          BlockCategory  @default(CUSTOM)
  repeatRules       Json?
  schedulingMode    SchedulingMode @default(FLEXIBLE)
  notificationRules Json?
  isPrayerBlock     Boolean        @default(false)
  startTimeHint     String?
  daysOfWeek        Int[]          @default([])
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  user            User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        RoutineTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  scheduledBlocks ScheduledBlock[]

  @@index([userId])
  @@index([templateId])
}

model ScheduleDay {
  id          String         @id @default(cuid())
  userId      String
  date        DateTime       @db.Date
  timezone    String
  source      ScheduleSource @default(GENERATED)
  generatedAt DateTime       @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks ScheduledBlock[]

  @@unique([userId, date])
  @@index([userId, date])
}

model ScheduledBlock {
  id             String               @id @default(cuid())
  scheduleDayId  String
  routineBlockId String?
  taskId         String?
  title          String
  color          String
  icon           String               @default("clock")
  category       BlockCategory        @default(CUSTOM)
  startTime      DateTime
  endTime        DateTime
  status         ScheduledBlockStatus @default(PLANNED)
  isFlexible     Boolean              @default(true)
  isPrayerBlock  Boolean              @default(false)
  sortOrder      Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  scheduleDay  ScheduleDay   @relation(fields: [scheduleDayId], references: [id], onDelete: Cascade)
  routineBlock RoutineBlock? @relation(fields: [routineBlockId], references: [id])
  task         Task?         @relation(fields: [taskId], references: [id])

  @@index([scheduleDayId, startTime])
}

model PrayerTimeCache {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  city      String?
  country   String?
  timings   Json
  fetchedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model PersonalRule {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  severity    RuleSeverity @default(IMPORTANT)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String
  action    AuditAction
  resource  String
  metadata  Json?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
